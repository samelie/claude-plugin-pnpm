#!/usr/bin/env bash
# session-start - SessionStart hook for team
# Preserves existing team-session directory/symlink if valid.
# Creates new session in $TMPDIR only if none exists or symlink target expired.
# Team subfolders (YYYYMMDD-{slug}) persist across CC sessions.

TMPBASE="${TMPDIR:-/tmp}"
SESSION_DIR="${TMPBASE}/team-kit-session-$(date +%Y%m%d-%H%M%S)"

# Preserve existing team-session if valid, else create new
if [ -L team-session ]; then
  # Symlink — verify target exists
  if [ -d "$(readlink team-session)" ]; then
    SESSION_DIR="$(readlink team-session)"
  else
    rm -f team-session
    mkdir -p "$SESSION_DIR"
    ln -s "$SESSION_DIR" team-session
  fi
elif [ -d team-session ]; then
  # Real directory — use as-is
  SESSION_DIR="$(pwd)/team-session"
else
  # No team-session — create new
  mkdir -p "$SESSION_DIR"
  ln -s "$SESSION_DIR" team-session
fi

# Update meta.json with current session start
echo "{\"startedAt\": \"$(date -u +%Y-%m-%dT%H:%M:%SZ)\", \"tmpPath\": \"${SESSION_DIR}\"}" > "$SESSION_DIR/meta.json"

# Build context
BASE="Team session directory ready at team-session/ (backed by ${SESSION_DIR}). Use write-findings and read-findings skills to exchange data between agents."

if [ -f .claude/team-domain.md ]; then
  DOMAIN_RAW=$(cat .claude/team-domain.md)
  FULL_CTX=$(printf '%s\n\n--- DOMAIN CONTEXT ---\n%s' "$BASE" "$DOMAIN_RAW")
else
  FULL_CTX="$BASE"
fi

# JSON-encode the context string safely
json_encode() {
  if command -v jq &>/dev/null; then
    printf '%s' "$1" | jq -Rs .
  elif command -v python3 &>/dev/null; then
    printf '%s' "$1" | python3 -c "import json, sys; print(json.dumps(sys.stdin.read()))"
  else
    # fallback: escape basics for JSON string
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s=$(printf '%s' "$s" | awk '{if(NR>1) printf "\\n"; printf "%s", $0}')
    printf '"%s"' "$s"
  fi
}

ENCODED=$(json_encode "$FULL_CTX")
echo "{\"hookSpecificOutput\":{\"hookEventName\":\"SessionStart\",\"additionalContext\":${ENCODED}}}"
